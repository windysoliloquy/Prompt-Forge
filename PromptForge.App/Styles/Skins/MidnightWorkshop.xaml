<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Color x:Key="AppBackgroundColor">#FF171B23</Color>
    <Color x:Key="CardColor">#FF1F2530</Color>
    <Color x:Key="BorderColor">#FF334155</Color>
    <Color x:Key="AccentColor">#FF6FB0FF</Color>
    <Color x:Key="AccentColorHover">#FF5297EA</Color>
    <Color x:Key="AccentSoftColor">#FF263B5A</Color>
    <Color x:Key="TextPrimaryColor">#FFF2F5FB</Color>
    <Color x:Key="TextMutedColor">#FFB5C0D0</Color>
    <Color x:Key="InputBackgroundColor">#FF252C39</Color>
    <Color x:Key="SubtleSurfaceColor">#FF232A36</Color>
    <Color x:Key="ShadowColor">#FF000000</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentColorHover}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource InputBackgroundColor}" />
    <SolidColorBrush x:Key="SubtleSurfaceBrush" Color="{StaticResource SubtleSurfaceColor}" />
    <SolidColorBrush x:Key="ComboBoxBackgroundBrush" Color="#FFF2F4F8" />
    <SolidColorBrush x:Key="ComboBoxForegroundBrush" Color="#FF111827" />
    <SolidColorBrush x:Key="ComboBoxDropDownBackgroundBrush" Color="#FFF2F4F8" />
    <SolidColorBrush x:Key="ComboBoxDropDownForegroundBrush" Color="#FF111827" />

    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FFF2F4F8" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FFF2F4F8" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#FFF8FAFC" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#FFD4D9E2" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FF111827" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FF111827" />
    <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#FF6B7280" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FFB8D1FF" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FF111827" />
</ResourceDictionary>
